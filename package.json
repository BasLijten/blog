{
  "name": "flexible-gatsby",
  "private": true,
  "description": "A starter for a paginated blog powered by Gatsby and Markdown",
  "version": "1.2.0",
  "author": "Kinyanjui Wangonya",
  "bugs": {
    "url": "https://github.com/wangonya/flexible-gatsby/issues"
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@deckdeckgo/highlight-code": "^4.4.0",
    "cross-env": "^10.1.0",
    "gatsby": "^5",
    "gatsby-adapter-netlify": "^1",
    "gatsby-plugin-feed": "^5",
    "gatsby-plugin-google-gtag": "^5",
    "gatsby-plugin-image": "^3",
    "gatsby-plugin-manifest": "^5",
    "gatsby-plugin-react-helmet": "^6",
    "gatsby-plugin-sass": "^6",
    "gatsby-plugin-sharp": "^5",
    "gatsby-plugin-sitemap": "^6",
    "gatsby-plugin-webfonts": "^2.3.2",
    "gatsby-remark-copy-linked-files": "^6",
    "gatsby-remark-embed-video": "^3.2.1",
    "gatsby-remark-highlight-code": "^3.3.0",
    "gatsby-remark-images": "^7",
    "gatsby-remark-katex": "^7",
    "gatsby-source-filesystem": "^5",
    "gatsby-transformer-remark": "^6",
    "gatsby-transformer-sharp": "^5",
    "katex": "^0.16.45",
    "lodash": "^4.18.1",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0"
  },
  "devDependencies": {
    "@netlify/plugin-lighthouse": "^6.0.4",
    "eslint": "^8",
    "eslint-plugin-react": "^7.28.0",
    "prettier": "^3.8.1",
    "sass": "^1"
  },
  "homepage": "https://github.com/wangonya/flexible-gatsby",
  "keywords": [
    "gatsby"
  ],
  "license": "MIT",
  "main": "n/a",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangonya/flexible-gatsby.git"
  },
  "resolutions": {
    "socket.io-parser": ">=4.2.6",
    "flatted": ">=3.4.2",
    "yaml": ">=2.8.3",
    "brace-expansion": "^1.1.13",
    "braces": ">=3.0.3",
    "cross-spawn": ">=7.0.5",
    "ws": ">=8.17.1",
    "axios": ">=1.7.4",
    "form-data": ">=4.0.1",
    "semver": ">=7.5.2",
    "serialize-javascript": ">=6.0.2"
  },
  "scripts": {
    "build": "gatsby build --log-pages",
    "dev": "gatsby develop",
    "develop": "gatsby develop",
    "test": "echo \"Write tests! -> https://gatsby.app/unit-testing\"",
    "lint": "eslint --ext .js,.jsx --ignore-pattern public .",
    "format": "prettier --trailing-comma es5 --no-semi --single-quote --write \"src/**/*.js\" \"content/**/*.md\"",
    "fix-semi": "eslint --quiet --ignore-pattern node_modules --ignore-pattern public --parser babel-eslint --no-eslintrc --rule '{\"semi\": [2, \"never\"], \"no-extra-semi\": [2]}' --fix gatsby-node.js"
  }
}
